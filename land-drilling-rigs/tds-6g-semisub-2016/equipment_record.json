  "capabilities": [
    {
      "number": "01",
      "title": "9,840 ft Rated DP Platform",
      "body": "Kongsberg K-POS DP system with 8x 4,800 kW Thrustmaster azimuth thrusters enables full dynamic positioning to 9,840 ft water depth \u2014 or switch to 8-point Rolls-Royce mooring for extended campaigns."
    },
    {
      "number": "02",
      "title": "5,750 HP Drawworks",
      "body": "The NOV SSGD drawworks delivers 5,750 HP for efficient tripping on ultra-deep wells. Paired with the NOV TDX-1000 top drive (1,000 ST, 91,000 ft-lbs at 115 rpm) and passive/active heave compensation."
    },
    {
      "number": "03",
      "title": "Triple-Pit Segregated Mud System",
      "body": "Simultaneously handles three fluid types \u2014 WBM, NAF, and brine \u2014 with 15,051 bbl total liquid mud storage, 6x NOV VSM Multisizer shakers, and four 2,200 HP mud pumps at 7,500 psi."
    },
    {
      "number": "04",
      "title": "6th-Gen Dual-Derrick-Ready Design",
      "body": "2x NOV HR IV Rackers, 2x NOV MPT Iron Roughnecks, and a powered mousehole enable efficient dual-activity operations, maximizing time on bottom in ultra-deepwater environments."
    }
  ],
